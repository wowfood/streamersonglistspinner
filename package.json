{
  "name": "song-spinner",
  "version": "1.0.0",
  "description": "Song queue spinner for streamers",
  "scripts": {
    "start": "node server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "version:patch": "node generate-version.js patch",
    "version:minor": "node generate-version.js minor",
    "version:major": "node generate-version.js major"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "SongSpinner/scripts/**/*.js",
      "!SongSpinner/scripts/**/*.test.js"
    ]
  }
}
